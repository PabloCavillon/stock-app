generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SELLER
  WAREHOUSE
  WATCHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MovementType {
  IN
  OUT
}

enum StoreOrderStatus {
  PENDING
  PAYMENT_REGISTERED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PromoType {
  PERCENTAGE
  FIXED_PRICE
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  role      Role      @default(SELLER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders         Order[]
  stockMovements StockMovement[]
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders        Order[]
  storeCustomer StoreCustomer?
}

model Product {
  id          String    @id @default(uuid())
  sku         String    @unique
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  category    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  orderItems      OrderItem[]
  stockMovements  StockMovement[]
  kitItems        KitItem[]
  promoProducts   PromoProduct[]
  storeOrderItems StoreOrderItem[]
}

model Order {
  id         String      @id @default(uuid())
  code       String      @unique
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  status     OrderStatus @default(PENDING)
  total      Decimal     @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  dollarRate Decimal?    @db.Decimal(10, 2)

  items          OrderItem[]
  stockMovements StockMovement[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  @@unique([orderId, productId])
}

model StockMovement {
  id        String       @id @default(uuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  orderId   String?
  order     Order?       @relation(fields: [orderId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())
}

model StoreCustomer {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  passwordHash   String
  phone          String?
  address        String?
  guildDiscount  Decimal   @default(0) @db.Decimal(5, 2)
  volumeDiscount Decimal   @default(0) @db.Decimal(5, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Vínculo opcional con cliente del panel
  customerId String?   @unique // @unique porque un Customer = un StoreCustomer máximo
  customer   Customer? @relation(fields: [customerId], references: [id])

  storeOrders StoreOrder[]
}

model Kit {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2) // USD
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items           KitItem[]
  promoProducts   PromoProduct[]
  storeOrderItems StoreOrderItem[]
}

model KitItem {
  id        String  @id @default(uuid())
  kitId     String
  kit       Kit     @relation(fields: [kitId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@unique([kitId, productId])
}

model Promo {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        PromoType
  // Si PERCENTAGE: ej. 15.00 = 15% off. Si FIXED_PRICE: precio fijo en USD
  value       Decimal   @db.Decimal(10, 2)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products PromoProduct[]
}

// Tabla pivote: una promo puede aplicar a productos y/o kits
model PromoProduct {
  id        String   @id @default(uuid())
  promoId   String
  promo     Promo    @relation(fields: [promoId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  kitId     String?
  kit       Kit?     @relation(fields: [kitId], references: [id])

  @@unique([promoId, productId])
  @@unique([promoId, kitId])
}

model StoreOrder {
  id              String           @id @default(uuid())
  code            String           @unique
  storeCustomerId String
  storeCustomer   StoreCustomer    @relation(fields: [storeCustomerId], references: [id])
  status          StoreOrderStatus @default(PENDING)

  // Snapshot del dólar al momento de crear la orden (referencia)
  dollarRateAtCreation Decimal  @db.Decimal(10, 2)
  // Se completa cuando el admin registra el pago
  dollarRateAtPayment  Decimal? @db.Decimal(10, 2)

  subtotalUsd     Decimal @db.Decimal(10, 2) // suma de items en USD
  discountApplied Decimal @db.Decimal(5, 2) // % efectivo aplicado (el mayor)
  discountType    String? // "GUILD" | "VOLUME" | "NONE"

  // Totales en ARS — se calculan al registrar el pago con dollarRateAtPayment
  totalArs Decimal? @db.Decimal(12, 2)

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items StoreOrderItem[]
}

model StoreOrderItem {
  id           String     @id @default(uuid())
  storeOrderId String
  storeOrder   StoreOrder @relation(fields: [storeOrderId], references: [id])

  // O producto O kit (uno de los dos)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  kitId     String?
  kit       Kit?     @relation(fields: [kitId], references: [id])

  quantity     Int
  unitPriceUsd Decimal @db.Decimal(10, 2) // snapshot del precio al crear la orden
  promoId      String? // si tenía promo aplicada

  @@unique([storeOrderId, productId])
  @@unique([storeOrderId, kitId])
}
